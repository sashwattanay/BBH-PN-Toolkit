Cell[CellGroupData[{

Cell["\<\
Then go to Sec. B-6-B to set the plotting parameters, which we now explain. \
Here we plot using the function DefPlot\
\>", "Subsection",
 CellChangeTimes->{
  3.985869522823349*^9, {3.985874628684211*^9, 3.9858746500397873`*^9}, 
