            RowBox[{
             RowBox[{"Cos", "[", "\[Xi]1L", "]"}], 
             RowBox[{"Cos", "[", "\[Xi]2L", "]"}]}], ",", " ", 
            RowBox[{"Sin", "[", "\[Xi]2L", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"Sin", "[", "\[Xi]1L", "]"}], 
