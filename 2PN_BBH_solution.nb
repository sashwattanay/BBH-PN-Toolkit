                    RowBox[{"rvec", "/", "r"}], ",", "pvec"}], "]"}], "^", 
                  "2"}], " ", "\[Nu]"}], "+", 
                RowBox[{
                 RowBox[{"p", "^", "2"}], " ", 
                 RowBox[{"(", 
                  RowBox[{"3", "+", "\[Nu]"}], ")"}]}]}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"2", " ", "r"}], ")"}]}]}], ")"}]}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"seffdl", " ", "\[Epsilon]"}], ")"}], "/", 
           RowBox[{"r", "^", "3"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"h0", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"p", "^", "2"}], "/", "2"}], "-", 
          RowBox[{"1", "/", "r"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"EulMat", "=", 
         RowBox[{"computeEulerMatrix", "[", "jvec", "]"}]}], ";", 
        RowBox[{"InvEulMat", "=", 
         RowBox[{"Inverse", "[", "EulMat", "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"\[CapitalSigma]1", "=", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"s1vec", ".", "s2vec"}], "/", 
