         "\[IndentingNewLine]", "Nprec", ",", "Uprec", ",", "Tprec", ",", 
         "Torb", ",", "freq\[Xi]1L", ",", "freqcos\[Kappa]1"}], "}"}], ",", 
       RowBox[{
        RowBox[{"c", "=", 
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", "\[Epsilon]", "]"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"ORB", "==", "\"\<Yes\>\""}], ",", " ", 
          RowBox[{"o", " ", "=", " ", "1"}]}], "]"}], ";", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"ORB", "==", "\"\<No\>\""}], ",", " ", 
          RowBox[{"o", " ", "=", " ", "0"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"M", "=", 
         RowBox[{"N", "[", 
          RowBox[{"m1", "+", "m2"}], "]"}]}], ";", 
        RowBox[{"\[Mu]", "=", 
         RowBox[{"N", "[", 
          RowBox[{"m1", " ", 
           RowBox[{"m2", "/", "M"}]}], "]"}]}], ";", 
        RowBox[{"\[Nu]", "=", 
         RowBox[{"\[Mu]", "/", "M"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"rvec", "=", 
         RowBox[{"N", "[", 
          RowBox[{"R0", "/", "M"}], "]"}]}], ";", 
        RowBox[{"r", "=", 
         RowBox[{"Norm", "[", "rvec", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"pvec", "=", 
         RowBox[{"N", "[", 
          RowBox[{"P0", "/", "\[Mu]"}], "]"}]}], ";", 
        RowBox[{"p", "=", 
         RowBox[{"Norm", "[", "pvec", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"SS10", "=", 
         RowBox[{"N", "[", 
          RowBox[{"S10", " ", 
           RowBox[{"Sqrt", "[", "\[Epsilon]", "]"}]}], "]"}]}], ";", 
        RowBox[{"s1vec", "=", 
         RowBox[{"SS10", "/", 
          RowBox[{"(", 
           RowBox[{"\[Mu]", " ", "M"}], ")"}]}]}], ";", 
        RowBox[{"s1", "=", 
         RowBox[{"Norm", "[", "s1vec", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"SS20", "=", 
         RowBox[{"N", "[", 
          RowBox[{"S20", " ", 
           RowBox[{"Sqrt", "[", "\[Epsilon]", "]"}]}], "]"}]}], ";", 
        RowBox[{"s2vec", "=", 
         RowBox[{"SS20", "/", 
          RowBox[{"(", 
           RowBox[{"\[Mu]", " ", "M"}], ")"}]}]}], ";", 
        RowBox[{"s2", "=", 
         RowBox[{"Norm", "[", "s2vec", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"lvec", "=", 
         RowBox[{"Cross", "[", 
          RowBox[{"rvec", ",", "pvec"}], "]"}]}], ";", 
        RowBox[{"l", "=", 
         RowBox[{"Norm", "[", "lvec", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"jvec", "=", 
         RowBox[{"lvec", "+", "s1vec", "+", "s2vec"}]}], ";", 
        RowBox[{"j", "=", 
         RowBox[{"Norm", "[", "jvec", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"\[Delta]1", "=", 
         RowBox[{"2", " ", "\[Nu]", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"3", " ", 
             RowBox[{"m2", "/", 
              RowBox[{"(", 
               RowBox[{"4", " ", "m1"}], ")"}]}]}]}], ")"}]}]}], ";", 
        RowBox[{"\[Delta]2", "=", 
         RowBox[{"2", " ", "\[Nu]", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"3", " ", 
             RowBox[{"m1", "/", 
              RowBox[{"(", 
               RowBox[{"4", " ", "m2"}], ")"}]}]}]}], ")"}]}]}], ";", 
        RowBox[{"seffdl", "=", 
         RowBox[{"Dot", "[", 
          RowBox[{"lvec", ",", 
           RowBox[{
            RowBox[{"\[Delta]1", " ", "s1vec"}], "+", 
            RowBox[{"\[Delta]2", " ", "s2vec"}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"h", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"p", "^", "2"}], "/", "2"}], "-", 
          RowBox[{"1", "/", "r"}], "+", " ", 
          RowBox[{"o", " ", "\[Epsilon]", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"1", "/", 
              RowBox[{"(", 
               RowBox[{"2", " ", 
                RowBox[{"r", "^", "2"}]}], ")"}]}], "+", 
             RowBox[{
              RowBox[{"1", "/", "8"}], " ", 
              RowBox[{"p", "^", "4"}], " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "1"}], "+", 
                RowBox[{"3", " ", "\[Nu]"}]}], ")"}]}], "-", 
             RowBox[{
              RowBox[{"(", 
