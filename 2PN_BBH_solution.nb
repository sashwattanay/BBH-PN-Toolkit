  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"sphericalAngles", "[", "V_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"polarAngJ", ",", "azimuthAngJ"}], "}"}], ",", 
       RowBox[{
        RowBox[{"polarAngJ", "=", 
         RowBox[{
          RowBox[{"ToSphericalCoordinates", "[", 
           RowBox[{"Re", "[", "V", "]"}], "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"azimuthAngJ", "=", 
         RowBox[{
          RowBox[{"ToSphericalCoordinates", "[", 
           RowBox[{"Re", "[", "V", "]"}], "]"}], "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", 
         RowBox[{"{", 
          RowBox[{"polarAngJ", ",", "azimuthAngJ"}], "}"}], "]"}], ";"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"vectorComponents", "[", 
      RowBox[{"V_", ",", "\[Theta]_", ",", "\[CurlyPhi]_"}], "]"}], ":=", 
     RowBox[{"V", "*", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "*", 
         RowBox[{"Cos", "[", "\[CurlyPhi]", "]"}]}], ",", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "*", 
         RowBox[{"Sin", "[", "\[CurlyPhi]", "]"}]}], ",", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"computeEulerMatrix", "[", "jvec_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "\[Theta]", ",", "\[Phi]", ",", "cos\[Theta]", ",", "sin\[Theta]", ",",
          "cos\[Phi]", ",", "sin\[Phi]"}], "}"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", "\[Phi]"}], "}"}], "=", 
         RowBox[{
          RowBox[{"sphericalAngles", "[", "jvec", "]"}], "+", 
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"cos\[Theta]", "=", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ";", 
        RowBox[{"sin\[Theta]", "=", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"cos\[Phi]", "=", 
         RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ";", 
        RowBox[{"sin\[Phi]", "=", 
         RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"N", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"cos\[Phi]", ",", "sin\[Phi]", ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"-", "sin\[Phi]"}], "*", "cos\[Theta]"}], ",", 
             RowBox[{"cos\[Phi]", "*", "cos\[Theta]"}], ",", "sin\[Theta]"}], 
            "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"sin\[Phi]", "*", "sin\[Theta]"}], ",", 
             RowBox[{
              RowBox[{"-", "cos\[Phi]"}], "*", "sin\[Theta]"}], ",", 
             "cos\[Theta]"}], "}"}]}], "}"}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", "===", "===", "===", "===", "===", "==="}], "=", 
