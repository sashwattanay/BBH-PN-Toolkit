        "lvecLabFrame", "+", "s1vecLabFrame", "+", "s2vecLabFrame"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rNorm", "=", 
        RowBox[{"Norm", "@", "rvecLabFrame"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Euler", " ", "Matrix", " ", "from", " ", "Lab", " ", "to", " ", "J", 
