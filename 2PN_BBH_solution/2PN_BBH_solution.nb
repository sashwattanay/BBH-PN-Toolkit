            RowBox[{
             RowBox[{"-", 
              RowBox[{"Cos", "[", "\[Xi]1L", "]"}]}], 
             RowBox[{"Sin", "[", "\[Xi]2L", "]"}]}], ",", " ", 
            RowBox[{"Cos", "[", "\[Xi]2L", "]"}]}], "}"}]}], "}"}]}], ";", 
       "      ", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"r", " ", "vector", " ", "in", " ", "L", " ", "frame"}], 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"rvecLframe", "=", 
        RowBox[{"JtoLEulMat", ".", "LabtoJEulMat", ".", "rvecLabFrame"}]}], 
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"AzimuthAngle", " ", "of", " ", "rvec", " ", "in", " ", 
         RowBox[{"Lframe", " ", ":", " ", 
          RowBox[{"what", " ", "we", " ", "want"}]}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"rvecAzimuthAngleLframe", "=", 
        RowBox[{
         RowBox[{"sphericalAngles", "[", "rvecLframe", "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
