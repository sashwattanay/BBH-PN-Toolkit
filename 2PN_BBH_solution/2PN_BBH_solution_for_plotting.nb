Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "==="}], "=", "=="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"GEOMETRY", "&"}], " ", "EULER", " ", "MATRICES"}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", 
     RowBox[{"==", "=="}]}], "=", 
    RowBox[{"===", "=="}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"sphericalAngles", "[", "V_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"polarAngJ", ",", "azimuthAngJ"}], "}"}], ",", 
       RowBox[{
        RowBox[{"polarAngJ", "=", 
         RowBox[{
          RowBox[{"ToSphericalCoordinates", "[", 
           RowBox[{"Re", "[", "V", "]"}], "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"azimuthAngJ", "=", 
         RowBox[{
          RowBox[{"ToSphericalCoordinates", "[", 
           RowBox[{"Re", "[", "V", "]"}], "]"}], "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", 
         RowBox[{"{", 
          RowBox[{"polarAngJ", ",", "azimuthAngJ"}], "}"}], "]"}], ";"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"vectorComponents", "[", 
      RowBox[{"V_", ",", "\[Theta]_", ",", "\[CurlyPhi]_"}], "]"}], ":=", 
     RowBox[{"V", "*", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "*", 
         RowBox[{"Cos", "[", "\[CurlyPhi]", "]"}]}], ",", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "*", 
         RowBox[{"Sin", "[", "\[CurlyPhi]", "]"}]}], ",", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"computeEulerMatrix", "[", "jvec_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "\[Theta]", ",", "\[Phi]", ",", "cos\[Theta]", ",", "sin\[Theta]", 
         ",", "cos\[Phi]", ",", "sin\[Phi]"}], "}"}], ",", 
       RowBox[{
