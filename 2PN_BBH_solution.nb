          RowBox[{"\"\<S\>\"", ",", "\"\<2z\>\""}], "]"}]}], "}"}]}], "}"}]}],
     ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Lhat", "[", "v_", "]"}], ":=", 
     RowBox[{"v", "/", 
      RowBox[{"Norm", "[", "v", "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
   "(*", "*******************************************************************************************************************)"}\
], "\[IndentingNewLine]", 
