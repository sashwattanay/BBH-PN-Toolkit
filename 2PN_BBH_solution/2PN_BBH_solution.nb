     RowBox[{"t_", ",", "NumModel_", ",", "data_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "vectorComponents", ",", "rvecLabFrame", ",", "pvecLabFrame", ",", 
        "s1vecLabFrame", ",", "s2vecLabFrame", ",", "lvecLabFrame", ",", 
        "jvecLabFrame", ",", "LabtoJEulMat", ",", "\[Theta]J", ",", "\[Phi]J",
         ",", "lsolJframe", ",", "lx", ",", "ly", ",", "lz", ",", "\[Xi]1L", 
