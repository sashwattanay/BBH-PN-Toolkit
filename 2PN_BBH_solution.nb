Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{"Findecc", "[", 
     RowBox[{"m1_", ",", "m2_", ",", "R0_", ",", "P0_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "h", ",", "l", ",", "pvec", ",", "rvec", ",", "p", ",", "r", ",", 
          "M", ",", "\[Mu]"}], "}"}], ",", 
        RowBox[{
         RowBox[{"M", "=", 
          RowBox[{"m1", "+", "m2"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"\[Mu]", "=", 
          RowBox[{
           RowBox[{"m1", " ", 
            RowBox[{"m2", "/", "Mrvec"}]}], "=", 
           RowBox[{
            RowBox[{"R0", "/", "Mpvec"}], "=", 
            RowBox[{
             RowBox[{"P0", "/", "\[Mu]r"}], "=", 
             RowBox[{
              RowBox[{
               RowBox[{"Norm", "[", "rvec", "]"}], "p"}], "=", 
              RowBox[{
               RowBox[{
                RowBox[{"Norm", "[", "pvec", "]"}], "h"}], "=", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"p", "^", "2"}], "/", "2"}], "-", 
                 RowBox[{"1", "/", "rl"}]}], "=", 
                RowBox[{
                 RowBox[{"Norm", "[", 
                  RowBox[{"Cross", "[", 
                   RowBox[{"rvec", ",", "pvec"}], "]"}], "]"}], "\[IndentingNewLine]", 
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"1", "+", 
                   RowBox[{"2", " ", "h", " ", 
                    RowBox[{"l", "^", "2"}]}]}], "]"}]}]}]}]}]}]}]}]}]}]}], 
       " ", "]"}], "//", 
      RowBox[{"Quiet", "\[IndentingNewLine]", "m1"}]}], "=", "10"}]}], ";", 
   RowBox[{"m2", "=", "9"}], ";", 
   RowBox[{"R0", "=", " ", 
