7a155e171905"]
}, Closed]],

Cell[CellGroupData[{

Cell["2. Physics Models & Plotting Indices", "Section",
 CellChangeTimes->{
  3.985869522829921*^9, {3.985873946590355*^9, 
   3.9858739467462053`*^9}},ExpressionUUID->"0c74fca3-dea6-4626-9e79-\
4e00d4f27fae"],

Cell["\<\
We can plot the phase space variable solution under various evolution \
schemes. Use these 7 indices in the graphing command DefPlot below in Sec. \
B-4 to select the evolution scheme.
Note: All models compute non-orbit averaged dynamics, except Index 3 which \
computes 'Orbit-Averaged' dynamics.\
\>", "Text",
 CellChangeTimes->{
  3.98586952283041*^9, {3.985874048158347*^9, 3.985874052272304*^9}, {
   3.985874398686821*^9, 3.985874409483199*^9}, {3.9858744420838327`*^9, 
   3.9858745115588217`*^9}},ExpressionUUID->"fbb49109-c9fa-488f-85fb-\
5490f63a77eb"],

Cell[BoxData[
 TagBox[GridBox[{
    {"Index", 
     RowBox[{"Physics", " ", "Model", " ", "Plotted"}], 
     RowBox[{"Hamiltonian", " ", "Equation"}], 
     RowBox[{"Code", " ", "Routine"}]},
    {"1", 
     RowBox[{
      RowBox[{"1.5", "PN", " ", "Spin"}], "-", 
      RowBox[{"Orbit", " ", 
       RowBox[{"(", "Analytic", ")"}]}]}], 
     RowBox[{"H", " ", "=", " ", 
      RowBox[{
       SubscriptBox["h", "N"], " ", "+", " ", 
       SubscriptBox["h", "1"], " ", "+", " ", 
       SubscriptBox["h", "so"]}]}], "Hflow1List"},
    {"2", 
     RowBox[{
      RowBox[{"2", "PN", " ", "Spin"}], "-", 
      RowBox[{"Spin", " ", 
       RowBox[{"(", "Analytic", ")"}]}]}], 
     RowBox[{"H", " ", "=", " ", 
      RowBox[{
       SubscriptBox["h", "N"], " ", "+", " ", 
       SubscriptBox["h", "1"], " ", "+", " ", 
       SubscriptBox["h", "so"], " ", "+", " ", 
       SubscriptBox["h", "2"], " ", "+", " ", 
       SubscriptBox["h", "ss"]}]}], "Hflow2SList"},
    {"3", 
     RowBox[{
      RowBox[{"2", "PN", " ", "Spin"}], "-", 
      RowBox[{"Spin", " ", "Orbit"}], "-", 
      RowBox[{"averaged", " ", 
       RowBox[{"(", "Analytic", ")"}]}]}], 
     RowBox[{"H", " ", "=", " ", 
      RowBox[{
       SubscriptBox["h", "N"], " ", "+", " ", 
       SubscriptBox["h", "1"], " ", "+", " ", 
       SubscriptBox["h", "so"], " ", "+", " ", 
       SubscriptBox["h", "2"], " ", "+", " ", 
       SubscriptBox["h", "ss"]}]}], "Hflow2SList"},
    {"4", 
     RowBox[{
      RowBox[{"1.5", "PN", " ", "Spin"}], "-", 
      RowBox[{"Orbit", " ", 
       RowBox[{"(", "Numerical", ")"}]}]}], 
     RowBox[{"H", " ", "=", " ", 
      RowBox[{
       SubscriptBox["h", "N"], " ", "+", " ", 
       SubscriptBox["h", "1"], " ", "+", " ", 
       SubscriptBox["h", "so"]}]}], "ComputeNum1"},
    {"5", 
     RowBox[{
      RowBox[{"2", "PN", " ", "Spin"}], "-", 
      RowBox[{"Spin", " ", 
       RowBox[{"(", "Numerical", ")"}]}]}], 
     RowBox[{"H", " ", "=", " ", 
      RowBox[{
       SubscriptBox["h", "N"], " ", "+", " ", 
       SubscriptBox["h", "1"], " ", "+", " ", 
       SubscriptBox["h", "so"], " ", "+", " ", 
       SubscriptBox["h", "2"], " ", "+", " ", 
       SubscriptBox["h", "ss"]}]}], "ComputeNum2S"},
    {"6", 
     RowBox[{"2", "PN", " ", "Pure", " ", "Orbital", " ", 
      RowBox[{"(", "Analytic", ")"}]}], 
     RowBox[{"H", " ", "=", " ", 
      RowBox[{
       SubscriptBox["h", "N"], " ", "+", " ", 
       SubscriptBox["h", "1"], " ", "+", " ", 
       RowBox[{
        SubscriptBox["h", "2"], " ", 
        RowBox[{"(", 
         RowBox[{"Spins", "=", "0"}], ")"}]}]}]}], "Hflow2SListFixedSpins"},
    {"7", 
     RowBox[{"2", "PN", " ", "Pure", " ", "Orbital", " ", 
      RowBox[{"(", "Numerical", ")"}]}], 
     RowBox[{"H", " ", "=", " ", 
      RowBox[{
       SubscriptBox["h", "N"], " ", "+", " ", 
       SubscriptBox["h", "1"], " ", "+", " ", 
       RowBox[{
        SubscriptBox["h", "2"], " ", 
        RowBox[{"(", 
         RowBox[{"Spins", "=", "0"}], ")"}]}]}]}], "ComputeNumOrb"}
   },
   AutoDelete->False,
   GridBoxAlignment->{"Columns" -> {{Left}}},
   GridBoxBackground->{"Columns" -> {{None}}, "Rows" -> {
       GrayLevel[0.85], None}},
   GridBoxFrame->{"Columns" -> {{True}}, "Rows" -> {{True}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Grid"]], "Text",
 CellChangeTimes->{
  3.985869522831163*^9, {3.985875046302124*^9, 3.985875243955338*^9}, {
   3.985875564392211*^9, 
   3.985875570443117*^9}},ExpressionUUID->"45fcd183-9061-40e8-bcb4-\
a7c46281f0dc"]
}, Closed]],

Cell[CellGroupData[{

Cell["3. Initialization", "Section",
 CellChangeTimes->{
  3.985869522822432*^9, {3.985873970936699*^9, 3.985873971065834*^9}, {
   3.985874561637528*^9, 3.9858745620040092`*^9}, {3.98587669304668*^9, 
   3.9858766941626987`*^9}},ExpressionUUID->"72f553c7-2d2c-4a01-93cb-\
53701d8c234b"],

Cell[CellGroupData[{

Cell["Go to Sec. B-0 below and set things up.", "Subsection",
 CellChangeTimes->{
  3.985869522823349*^9, {3.985874628684211*^9, 
   3.9858746500397873`*^9}},ExpressionUUID->"8d3badd5-cdcb-4ee8-b495-\
81c1d8229f53"],

Cell[TextData[{
 "Orb (for analytical solutions) and NumOrb (for numerical solutions): \
Toggles the purely orbital corrections ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["h", "1"]}], TraditionalForm]],ExpressionUUID->
  "a357d415-41f7-40f2-b953-4d3e23c8e972"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "2"], TraditionalForm]],ExpressionUUID->
  "f1a41a30-b521-4cb0-8133-42ebd45e4e4d"],
 "). Default is \"Yes\". If set to \"No\", the purely orbital parts of the \
Hamiltonian (without spins) ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "1"], TraditionalForm]],ExpressionUUID->
  "4728865f-8011-45fc-8055-ab033fd3f88d"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "2"], TraditionalForm]],ExpressionUUID->
  "13af0757-7d4c-447b-a22b-66b00c09436f"],
 " are ignored, and equations of motion change accordingly. "
}], "Item",
 CellChangeTimes->{
  3.985869522824047*^9, {3.985869613785626*^9, 3.985869702239683*^9}, {
   3.985874691193995*^9, 3.985874753295467*^9}, {3.985876204270629*^9, 
   3.985876217264694*^9}},ExpressionUUID->"584b3cc4-556d-4724-9349-\
15f6392b9266"],

Cell[TextData[{
 "QKP: This is valid only for \[OpenCurlyDoubleQuote]Index 1\
\[CloseCurlyDoubleQuote] solution mentioned in the above table. It decides \
which baseline solution for |",
 StyleBox["R",
  FontWeight->"Bold"],
 "| = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", 
    StyleBox[
     RowBox[{
      SubscriptBox["R", "1"], "-", 
      SubscriptBox["R", "2"]}],
     FontWeight->"Bold"]}], TraditionalForm]],ExpressionUUID->
  "355d24c8-7c7f-43a5-a768-11665be1b8bd"],
 " ",
 "|",
 " (orbital separation vector norm) is to be injected for computing spin \
solutions; see Eq. 3.5 of https://arxiv.org/abs/1908.02927. In this paper, \
the Newtonian solution was injected. We have two options. Choosing \
\[OpenCurlyDoubleQuote]N\[CloseCurlyDoubleQuote] injects the Newtonian \
solution for |",
 StyleBox["R",
  FontWeight->"Bold"],
 "|",
 " (just like https://arxiv.org/abs/1908.02927), whereas choosing \
\[OpenCurlyDoubleQuote]SO\[CloseCurlyDoubleQuote] injects the 1.5PN solution \
for |",
 StyleBox["R",
  FontWeight->"Bold"],
 "|. Our default value is \[OpenCurlyDoubleQuote]SO\[CloseCurlyDoubleQuote]."
}], "Item",
 CellChangeTimes->{
  3.985869522824844*^9, {3.985869725819049*^9, 3.985869767655772*^9}, {
   3.985869802464562*^9, 3.985869812388605*^9}, {3.985869855391556*^9, 
   3.985870004371686*^9}, {3.9858738966323023`*^9, 3.985873926774234*^9}, {
   3.985874767950861*^9, 3.985874808151946*^9}, {3.9858748943573313`*^9, 
   3.9858748976140823`*^9}, {3.9858752707668467`*^9, 3.985875275194641*^9}, {
   3.985876053242794*^9, 
   3.985876071580926*^9}},ExpressionUUID->"34fc1647-44be-41f1-85bb-\
87635de87912"],

Cell[TextData[{
 "Torb: The rough orbital time period of the system, the approximate time in \
which |",
 StyleBox["R",
  FontWeight->"Bold"],
 "| returns back to its original value."
}], "Item",
 CellChangeTimes->{
  3.985869522825858*^9, {3.9858748477584248`*^9, 3.985874863432453*^9}, {
   3.985874900787939*^9, 
   3.985874901198495*^9}},ExpressionUUID->"8c0de140-f734-4862-946e-\
51cbafa1f2f7"],

Cell["\<\
end[data]: Total numerical integration runtime and plot display time.\
\>", "Item",
 CellChangeTimes->{
  3.985869522826635*^9, {3.985874876756136*^9, 3.98587488152495*^9}, {
   3.985876699750287*^9, 
   3.985876700549287*^9}},ExpressionUUID->"4b01a6eb-063a-415e-98e3-\
9117fd19ae5f"],

Cell[CellGroupData[{

Cell[TextData[{
 "userData: Your initial data formatted as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["m", "1"]}], TraditionalForm]],ExpressionUUID->
  "1d52fbeb-b9c3-47be-908b-06ffffd19711"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "2"], TraditionalForm]],ExpressionUUID->
  "2b63a729-6be1-4ea5-86c6-b46f01cac7e8"],
 ", ",
 StyleBox["R",
  FontWeight->"Bold"],
 ", ",
 StyleBox["P",
  FontWeight->"Bold"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "1"], 
    StyleBox["/",
     FontWeight->"Plain"], 
    SuperscriptBox[
     StyleBox["\[Epsilon]",
      FontWeight->"Plain"], 
     RowBox[{"1", "/", "2"}]]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"2c8abf3b-b0a1-4337-a1af-7b69151a7d5f"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "2"], 
    StyleBox["/",
     FontWeight->"Plain"], 
    SuperscriptBox[
     StyleBox["\[Epsilon]",
      FontWeight->"Plain"], 
     RowBox[{"1", "/", "2"}]]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"3c942c53-b836-47ff-93c7-56f89c376d17"],
 ", \[Epsilon] = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "/", 
    SuperscriptBox["c", "2"]}], TraditionalForm]],ExpressionUUID->
  "5cd6b6ab-d938-4983-87fd-3af0e177e703"],
 "}. Here ",
 StyleBox["P",
  FontWeight->"Bold"],
 " = ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SubscriptBox["P", "1"],
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "2d66b488-4349-45f3-9de9-784ff221ec12"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", 
    SubscriptBox["P", "2"]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"a6646fb4-ad6e-4213-919c-f0c71a226ea1"],
 ", as we are working in the centre-of-mass frame"
}], "Item",
 CellChangeTimes->{
  3.985869522827108*^9, {3.985874912623331*^9, 3.985874945000763*^9}, {
   3.985876098697729*^9, 3.98587613580976*^9}, {3.985878531951727*^9, 
   3.98587855243038*^9}},ExpressionUUID->"22e3fe5d-ad63-403f-8171-\
bb34054b8a6a"],

Cell[TextData[{
 "Constraint: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "1"], TraditionalForm]],ExpressionUUID->
  "e9f8b135-cbb8-4996-964f-41247ca02c82"],
 " must be strictly greater than ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "2"], TraditionalForm]],ExpressionUUID->
  "2c13bc9a-65ae-4cd9-9495-2f11a361944e"],
 "."
}], "Subitem",
 CellChangeTimes->{
  3.985869522828656*^9, {3.985874948791696*^9, 
   3.985874955441215*^9}},ExpressionUUID->"201ea105-be0a-49b9-bd7f-\
a85c82e34587"],

Cell["Constants: G = 1.", "Subitem",
 CellChangeTimes->{
  3.98586952282952*^9, {3.985874961679434*^9, 
   3.9858749658083477`*^9}},ExpressionUUID->"50cb2c3a-8c76-45da-b9f6-\
6012b854573c"]
}, Open  ]]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["4. Setting up Plotting Parameters", "Section",
 CellChangeTimes->{
  3.9858695228318768`*^9, {3.985875626050473*^9, 
   3.985875640482892*^9}},ExpressionUUID->"767aa5f6-d935-40af-8162-\
4610d537d80b"],

Cell[CellGroupData[{

Cell["\<\
Then go to Sec. B-4-B to set the plotting parameters, which we now explain. \
Here we plot using the function DefPlot\
\>", "Subsection",
 CellChangeTimes->{
  3.985869522823349*^9, {3.985874628684211*^9, 3.9858746500397873`*^9}, 
   3.985875669756143*^9},ExpressionUUID->"46aeeffe-cff7-4e85-88e1-\
e6ca3f453aa5"],

Cell["\<\
Syntax: DefPlot[data, vector_number, component_number, time_min, time_max, \
{plot_indices}]\
\>", "Text",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.985869522832385*^9},
 FontFamily->"Courier",
 Background->GrayLevel[
  0.85],ExpressionUUID->"8cb050ab-657a-4561-abe2-c5aaba68ff73"],

Cell[TextData[{
 "vector_number: 1 (",
 StyleBox["R",
  FontWeight->"Bold"],
 "), 2 (",
 StyleBox["L",
  FontWeight->"Bold"],
 "), 3 (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "1"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"8aab022e-8b73-4881-b933-65df0e89edf2"],
 "), or 4 (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "2"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"623e46fa-dd0c-42d4-8bbc-6f203e059b3d"],
 ")."
}], "Item",
 CellChangeTimes->{
  3.985869522833458*^9, {3.9858754452972507`*^9, 
   3.985875478216494*^9}},ExpressionUUID->"6bd24c3c-2dad-4767-ae9e-\
ed2bed6e6659"],

Cell["\<\
component_number: 1 (x-component), 2 (y-component), or 3 (z-component).\
\>", "Item",
 CellChangeTimes->{
  3.985869522833911*^9, {3.985875484297421*^9, 
   3.98587549087123*^9}},ExpressionUUID->"5cc3ca53-ba65-442a-8f6e-\
220ea25a69b3"],

Cell["\<\
Example: DefPlot[data, 2, 3, tmin, tmax, {2, 3, 5}] graphs the z-component of \
Angular Momentum overlaying Analytical, Averaged, and Numerical 2PN.\
\>", "Text",
 CellChangeTimes->{3.985869522834282*^9, 
  3.98587551721881*^9},ExpressionUUID->"4809ff16-553f-4abc-94c8-1a3c511452e8"]
}, Open  ]]
}, Closed]],

