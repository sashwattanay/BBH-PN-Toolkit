        "\[IndentingNewLine]", 
        RowBox[{"\[CapitalSigma]2", "=", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"s2vec", ".", "lvec"}], "/", 
            RowBox[{"(", 
             RowBox[{"l", " ", "s2"}], ")"}]}], "+", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"\[Delta]1", " ", "s1"}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"\[Delta]2", " ", "s2"}], ")"}]}], " ", 
            RowBox[{
