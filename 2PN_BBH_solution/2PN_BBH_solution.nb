         RowBox[{"(", 
          RowBox[{"\[Mu]", " ", "M"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"lvecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "[", "t", "]"}], "/.", " ", 
           RowBox[{
