          "\[Epsilon]"}], "}"}], "=", 
        RowBox[{"Inputs", "[", "data", "]"}]}], ";", " ", 
       RowBox[{"M", "=", 
        RowBox[{"m1", "+", "m2"}]}], ";", " ", 
       RowBox[{"\[Mu]", "=", 
        RowBox[{"m1", " ", 
         RowBox[{"m2", " ", "/", "M"}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
