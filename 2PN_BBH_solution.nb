        "m1", ",", "m2", ",", "R0", ",", "P0", ",", "S10", ",", "S20", ",", 
        "\[Epsilon]", ",", "M", ",", "\[Mu]"}], "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "m1", ",", "m2", ",", "R0", ",", "P0", ",", "S10", ",", "S20", ",", 
          "\[Epsilon]"}], "}"}], "=", 
        RowBox[{"Inputs", "[", "data", "]"}]}], ";", " ", 
       RowBox[{"M", "=", 
        RowBox[{"m1", "+", "m2"}]}], ";", " ", 
       RowBox[{"\[Mu]", "=", 
        RowBox[{"m1", " ", 
         RowBox[{"m2", " ", "/", "M"}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Numerical", " ", "Values", " ", "at", " ", "time", " ", "t", " ", 
         "in", " ", "Lab", " ", "frame"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"rvecLabFrame", "=", 
