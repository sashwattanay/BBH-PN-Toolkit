Notebook[{

Cell[CellGroupData[{
Cell[TextData[{
 "Solutions to second post-Newtonian dynamics of spinning and eccentric \
binary black holes (accompanying arxiv:2603.20031)\n",
 StyleBox["Authors : Tom Colin (tom.colin@obspm.fr) and Sashwat Tanay \
(sashwattanay@gmail.com)", "Subtitle"]
}], "Title",
 CellChangeTimes->{{3.98587410955451*^9, 3.985874118416493*^9}, {
  3.9858742661622667`*^9, 3.985874267608967*^9}, {3.98587498656859*^9, 
