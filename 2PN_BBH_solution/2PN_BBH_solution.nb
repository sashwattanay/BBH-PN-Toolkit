            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", "M", ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"pvecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
