 CellAutoOverwrite->True,
 CellChangeTimes->{
  3.985869522818564*^9},ExpressionUUID->"8b8315d4-a2d2-4504-927e-\
d6c731ca9597"],

Cell[TextData[{
 "Before configuring the code, note the underlying Hamiltonian terms: \n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "full"], TraditionalForm]],ExpressionUUID->
  "5231e51f-31b4-4002-b563-ff93a2009c6d"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "N"], TraditionalForm]],ExpressionUUID->
  "c8a22b4c-ebdf-44d9-bd04-4e44c663d803"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", 
    RowBox[{"1", "PN"}]], TraditionalForm]],ExpressionUUID->
  "999b02fc-f7a6-4f3d-82ca-44e8c9a75513"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "so"], TraditionalForm]],ExpressionUUID->
  "ee96022c-0670-4809-8154-41cd132fceec"],
 " + ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["h", "2"]}], TraditionalForm]],ExpressionUUID->
  "5bb8f076-fb07-4d83-9210-6e408d29a726"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "ss"], TraditionalForm]],ExpressionUUID->
  "f1316846-bf96-4041-bc14-12d72e7f49f2"],
 ")"
}], "Text",
 CellChangeTimes->{
  3.985869522819234*^9, {3.9858739947080307`*^9, 3.98587403688061*^9}, {
   3.985875029079872*^9, 
   3.985875031351347*^9}},ExpressionUUID->"27efe2e4-5e2c-4e4c-b2ae-\
94f8e374ad70"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "N"], TraditionalForm]],ExpressionUUID->
  "bcdcec85-d843-48e6-9682-17f5aa7ed893"],
 " = Pure Newtonian gravity"
}], "Item",
 CellChangeTimes->{
  3.985869522820354*^9, {3.985869567914072*^9, 
   3.9858695713222113`*^9}},ExpressionUUID->"c767cd26-f729-487b-b60d-\
de0822217cf3"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "1"], TraditionalForm]],ExpressionUUID->
  "869e869d-0970-4246-aff3-3910c0c60920"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "2"], TraditionalForm]],ExpressionUUID->
  "49d04b77-1c66-493c-88d2-979e7c3a9484"],
 " = 1PN and 2PN purely orbital corrections"
}], "Item",
 CellChangeTimes->{
  3.985869522821033*^9, {3.985869574264979*^9, 
   3.985869583165408*^9}},ExpressionUUID->"afc3e970-5818-466c-a1cf-\
d81227e24ec0"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "so"], TraditionalForm]],ExpressionUUID->
