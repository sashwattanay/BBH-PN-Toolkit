   RowBox[{"(*", 
    RowBox[{"BASE", " ", "QUANTITIES", " ", "COMPUTATION", " ", 
     RowBox[{"(", 
      RowBox[{"t", "=", "0"}], ")"}]}], "*)"}], 
   RowBox[{"(*", " ", 
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
     RowBox[{"==", 
      RowBox[{"===", "===", "===", "===", "=="}]}]}], "*)"}], 
   RowBox[{
    RowBox[{
     RowBox[{"computeBaseQuantities1", "[", 
      RowBox[{
      "m1_", ",", "m2_", ",", "R0_", ",", "P0_", ",", "S10_", ",", "S20_", ",",
        "\[Epsilon]_", ",", "QKP_", ",", " ", "ORB_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "o", ",", " ", "c", ",", "M", ",", "\[Mu]", ",", "\[Nu]", ",", "rvec",
          ",", "pvec", ",", "r", ",", "p", ",", "SS10", ",", "s1vec", ",", 
         "s1", ",", "SS20", ",", "s2vec", ",", "s2", ",", "lvec", ",", "l", ",",
          "jvec", ",", "j", ",", "EulMat", ",", "InvEulMat", ",", "\[Delta]1",
          ",", "\[Delta]2", ",", "seffdl", ",", "h", ",", "h0", ",", 
         "\[IndentingNewLine]", "\[CapitalSigma]1", ",", "\[CapitalSigma]2", ",",
          "A3", ",", "A2", ",", "A1", ",", "A0", ",", "x2", ",", "x3", ",", 
         "x1", ",", "\[Beta]", ",", "SqA", ",", "JtoLframeEulMat0", ",", 
         "\[IndentingNewLine]", "n", ",", "nunscaled", ",", "nso", ",", 
         "nunscaledso", ",", "ar", ",", "arso", ",", "er", ",", "erso", ",", 
         "et", ",", "etso", ",", "e\[Phi]", ",", "e\[Phi]so", ",", "fP", ",", 
         "gP", ",", "f\[Phi]", ",", "g\[Phi]", ",", "\[CapitalPhi]", ",", "d",
          ",", "\[IndentingNewLine]", "\[Alpha]1l", ",", "\[Alpha]2l", ",", 
         "\[Beta]1l", ",", "\[Beta]2l", ",", "\[Alpha]1s1", ",", 
         "\[Alpha]2s1", ",", "\[Beta]1s1", ",", "\[Beta]2s1", ",", 
         "\[Beta]e\[Phi]so", ",", "\[Beta]erso", ",", "\[Beta]e\[Phi]", ",", 
         "\[Beta]er", ",", "\[IndentingNewLine]", "drdt0", ",", "u0testso", ",",
          "Absu0so", ",", "u0so", ",", "ver0so", ",", "ve\[Phi]0so", ",", 
         "t0so", ",", "sign", ",", "cos\[Kappa]10", ",", "Int30", ",", 
