   RowBox[{
    RowBox[{"AVG", "=", "\"\<No\>\""}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"AnOrb", "=", "\"\<No\>\""}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PlotAn15PN0", "[", 
      RowBox[{"t_", ",", "data_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"An1", "[", 
         RowBox[{"NorSO", ",", "AnOrb", " ", ",", 
          RowBox[{"{", "t", "}"}]}], "]"}], "[", "data", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"NumVec", ",", "NumComp"}], "]"}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"Analytical", " ", "1.5", "PN", " ", "0", "PN", " ", "QKP"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PlotAn15PN1", "[", 
      RowBox[{"t_", ",", "data_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"An2SK", "[", 
         RowBox[{"AVG", ",", "AnOrb", ",", 
          RowBox[{"{", "t", "}"}]}], "]"}], "[", "data", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"NumVec", ",", "NumComp"}], "]"}], "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Analytical", " ", "1.5", "PN", " ", "1", "PN", " ", "QKP"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PlotNum15PN", "[", 
      RowBox[{"t_", ",", "data_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Vector", "[", 
          RowBox[{"[", "NumVec", "]"}], "]"}], "[", "t", "]"}], "/.", " ", 
        RowBox[{
         RowBox[{"Num1", "[", "data", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "[", 
      RowBox[{"[", "NumComp", "]"}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Numerical", " ", "1.5", "PN"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PlotNum2PN", "[", 
      RowBox[{"t_", ",", "data_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Vector", "[", 
          RowBox[{"[", "NumVec", "]"}], "]"}], "[", "t", "]"}], "/.", " ", 
        RowBox[{
         RowBox[{"Num2S", "[", "data", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "[", 
      RowBox[{"[", "NumComp", "]"}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Numerical", " ", "2", "PN"}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
   "(*", "*******************************************************************************************************************)"}\
], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Export", " ", "Logic"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
   "(*", "*******************************************************************************************************************)"}\
], "\n", 
   RowBox[{
    RowBox[{"NpExport", "=", "100"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"NumVec", "=", "1"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Select", " ", "vector", " ", "index"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"NumComp", "=", "1"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Select", " ", "component", " ", "index"}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Generic", " ", "curve", " ", "exporter", " ", "for", " ", "multiple", " ",
      "curves"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ExportCurves", "[", 
      RowBox[{
      "data_", ",", "funcs_List", ",", "tmin_", ",", "tmax_", ",", 
       "filename_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"TorbVal", ",", "tVals", ",", "curves"}], "}"}], ",", 
       RowBox[{
        RowBox[{"TorbVal", "=", 
         RowBox[{"Torb", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"tVals", "=", 
         RowBox[{"Subdivide", "[", 
          RowBox[{"tmin", ",", "tmax", ",", 
           RowBox[{"NpExport", "-", "1"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"curves", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Transpose", "@", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"tVals", "/", "TorbVal"}], ",", 
              RowBox[{
               RowBox[{"funcs", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "@@@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"#", ",", "data"}], "}"}], "&"}], "/@", "tVals"}], 
                ")"}]}]}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"Length", "[", "funcs", "]"}]}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Export", "[", 
         RowBox[{"filename", ",", "curves", ",", "\"\<CSV\>\""}], "]"}], 
        ";"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Export", " ", "both", " ", "long", " ", "and", " ", "short", " ", 
     "timescale", " ", "data"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ExportData", "[", 
      RowBox[{"ddata1_", ",", "ddata2_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "TorbVal1", ",", "TprecVal1", ",", "TorbVal2", ",", "TprecVal2", ",", 
         "funcs"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"TorbVal1", "=", 
         RowBox[{"Torb", "[", "ddata1", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"TprecVal1", "=", 
         RowBox[{"Tprec", "[", "ddata1", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"TorbVal2", "=", 
         RowBox[{"Torb", "[", "ddata2", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"TprecVal2", "=", 
         RowBox[{"Tprec", "[", "ddata2", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"funcs", "=", 
         RowBox[{"{", 
          RowBox[{
          "PlotAn15PN0", ",", "PlotAn15PN1", ",", "PlotNum15PN", ",", 
           "PlotNum2PN"}], "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"ExportCurves", "[", 
         RowBox[{"ddata1", ",", "funcs", ",", 
          RowBox[{"50", "TorbVal1"}], ",", 
          RowBox[{"50.01", "TorbVal1"}], ",", "\"\<Rx_plot_Long.csv\>\""}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"ExportCurves", "[", 
         RowBox[{"ddata2", ",", "funcs", ",", 
          RowBox[{"30", "TorbVal2"}], ",", 
          RowBox[{"30.01", "TorbVal2"}], ",", "\"\<Rx_plot_Short.csv\>\""}], 
         "]"}], ";"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ExportData", "[", 
      RowBox[{"data1", ",", "data2"}], "]"}], "//", "Quiet"}], 
    ";"}]}]}]], "Input",
