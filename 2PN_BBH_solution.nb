       "\[IndentingNewLine]", 
       RowBox[{"RvecLabFrame", "=", " ", 
        RowBox[{"M", " ", 
         RowBox[{
          RowBox[{"Transpose", "[", "LabtoJEulMat", "]"}], " ", ".", " ", 
          RowBox[{"Inverse", "[", "JtoLEulMat", "]"}], ".", 
          RowBox[{"vectorComponents", "[", 
           RowBox[{"{", 
            RowBox[{"rNorm", ",", " ", 
             RowBox[{"\[Pi]", "/", "2"}], ",", "rvecAzimuthAngleLframe"}], 
            "}"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"Return", " ", "[", 
        RowBox[{"{", 
         RowBox[{"rvecAzimuthAngleLframe", ",", 
