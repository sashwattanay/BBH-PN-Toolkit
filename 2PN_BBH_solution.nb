            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", "\[Mu]", ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"s1vecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S1", "[", "t", "]"}], "/.", " ", 
           RowBox[{
            RowBox[{"NumModel", "[", "data", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Mu]", " ", "M"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"s2vecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S2", "[", "t", "]"}], "/.", " ", 
           RowBox[{
            RowBox[{"NumModel", "[", "data", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Mu]", " ", "M"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"lvecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "[", "t", "]"}], "/.", " ", 
           RowBox[{
