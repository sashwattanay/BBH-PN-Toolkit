Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "to", " ", "compute", " ", "the", " ", "azimuthal", " ", 
    "angle", " ", "of", " ", "R", " ", "vector", " ", "in", " ", "L", " ", 
    "frame"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"AzimuthalRvectorLframe", "[", 
     RowBox[{"t_", ",", "NumModel_", ",", "data_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "vectorComponents", ",", "rvecLabFrame", ",", "pvecLabFrame", ",", 
        "s1vecLabFrame", ",", "s2vecLabFrame", ",", "lvecLabFrame", ",", 
        "jvecLabFrame", ",", "LabtoJEulMat", ",", "\[Theta]J", ",", "\[Phi]J",
         ",", "lsolJframe", ",", "lx", ",", "ly", ",", "lz", ",", "\[Xi]1L", 
        ",", "\[Xi]2L", ",", "JtoLEulMat", ",", "rvecLframe", ",", "angles", 
        ",", "rNorm", ",", "rvecAzimuthAngleLframe", ",", "RvecLabFrame", ",",
         "m1", ",", "m2", ",", "R0", ",", "P0", ",", "S10", ",", "S20", ",", 
        "\[Epsilon]", ",", "M", ",", "\[Mu]"}], "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "m1", ",", "m2", ",", "R0", ",", "P0", ",", "S10", ",", "S20", ",", 
          "\[Epsilon]"}], "}"}], "=", 
        RowBox[{"Inputs", "[", "data", "]"}]}], ";", " ", 
       RowBox[{"M", "=", 
        RowBox[{"m1", "+", "m2"}]}], ";", " ", 
       RowBox[{"\[Mu]", "=", 
        RowBox[{"m1", " ", 
         RowBox[{"m2", " ", "/", "M"}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Numerical", " ", "Values", " ", "at", " ", "time", " ", "t", " ", 
         "in", " ", "Lab", " ", "frame"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"rvecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"R", "[", "t", "]"}], "/.", " ", 
           RowBox[{
            RowBox[{"NumModel", "[", "data", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", "M", ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"pvecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"P", "[", "t", "]"}], "/.", " ", 
           RowBox[{
            RowBox[{"NumModel", "[", "data", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", "\[Mu]", ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"s1vecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S1", "[", "t", "]"}], "/.", " ", 
           RowBox[{
            RowBox[{"NumModel", "[", "data", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Mu]", " ", "M"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"s2vecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S2", "[", "t", "]"}], "/.", " ", 
           RowBox[{
            RowBox[{"NumModel", "[", "data", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Mu]", " ", "M"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"lvecLabFrame", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "[", "t", "]"}], "/.", " ", 
           RowBox[{
            RowBox[{"NumModel", "[", "data", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Mu]", " ", "M"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"jvecLabFrame", "=", 
        RowBox[{
        "lvecLabFrame", "+", "s1vecLabFrame", "+", "s2vecLabFrame"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rNorm", "=", 
        RowBox[{"Norm", "@", "rvecLabFrame"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Euler", " ", "Matrix", " ", "from", " ", "Lab", " ", "to", " ", "J", 
         " ", "frame", " ", "at", " ", "all", " ", "times"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Theta]J", ",", " ", "\[Phi]J"}], "}"}], "=", 
        RowBox[{
         RowBox[{"sphericalAngles", "[", "jvecLabFrame", "]"}], "+", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}]}], ";", 
       RowBox[{"LabtoJEulMat", " ", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", "\[Phi]J", "]"}], ",", " ", 
            RowBox[{"Sin", "[", "\[Phi]J", "]"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              RowBox[{"Sin", "[", "\[Phi]J", "]"}]}], 
             RowBox[{"Cos", "[", "\[Theta]J", "]"}]}], ",", " ", 
            RowBox[{
             RowBox[{"Cos", "[", "\[Phi]J", "]"}], 
             RowBox[{"Cos", "[", "\[Theta]J", "]"}]}], ",", " ", 
            RowBox[{"Sin", "[", "\[Theta]J", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"Sin", "[", "\[Phi]J", "]"}], 
             RowBox[{"Sin", "[", "\[Theta]J", "]"}]}], ",", " ", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"Cos", "[", "\[Phi]J", "]"}]}], 
             RowBox[{"Sin", "[", "\[Theta]J", "]"}]}], ",", " ", 
            RowBox[{"Cos", "[", "\[Theta]J", "]"}]}], "}"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"L", " ", "vector", " ", "in", " ", "J", " ", "frame"}], 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"lsolJframe", "=", 
        RowBox[{"LabtoJEulMat", ".", "lvecLabFrame"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Euler", " ", "Matrix", " ", "from", " ", "J", " ", "to", " ", "L", 
         " ", "frame", " ", "at", " ", "time", " ", "t"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"lx", ",", "ly", ",", "lz"}], "}"}], " ", "=", " ", 
        "lsolJframe"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Xi]2L", ",", " ", "\[Xi]1L"}], "}"}], "=", 
        RowBox[{
         RowBox[{"sphericalAngles", "[", 
          RowBox[{"{", 
           RowBox[{"lx", ",", "ly", ",", "lz"}], "}"}], "]"}], "+", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"JtoLEulMat", " ", "=", 
        RowBox[{"{", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", "\[Xi]1L", "]"}], ",", " ", 
            RowBox[{"Sin", "[", "\[Xi]1L", "]"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              RowBox[{"Sin", "[", "\[Xi]1L", "]"}]}], 
             RowBox[{"Cos", "[", "\[Xi]2L", "]"}]}], ",", " ", 
            RowBox[{
             RowBox[{"Cos", "[", "\[Xi]1L", "]"}], 
             RowBox[{"Cos", "[", "\[Xi]2L", "]"}]}], ",", " ", 
            RowBox[{"Sin", "[", "\[Xi]2L", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"Sin", "[", "\[Xi]1L", "]"}], 
             RowBox[{"Sin", "[", "\[Xi]2L", "]"}]}], ",", " ", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"Cos", "[", "\[Xi]1L", "]"}]}], 
             RowBox[{"Sin", "[", "\[Xi]2L", "]"}]}], ",", " ", 
            RowBox[{"Cos", "[", "\[Xi]2L", "]"}]}], "}"}]}], "}"}]}], ";", 
       "      ", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"r", " ", "vector", " ", "in", " ", "L", " ", "frame"}], 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"rvecLframe", "=", 
        RowBox[{"JtoLEulMat", ".", "LabtoJEulMat", ".", "rvecLabFrame"}]}], 
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"AzimuthAngle", " ", "of", " ", "rvec", " ", "in", " ", 
         RowBox[{"Lframe", " ", ":", " ", 
          RowBox[{"what", " ", "we", " ", "want"}]}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"rvecAzimuthAngleLframe", "=", 
        RowBox[{
         RowBox[{"sphericalAngles", "[", "rvecLframe", "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Conistency", " ", "check"}], ",", " ", 
         RowBox[{"have", " ", "to", " ", "recover", " ", "R0"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"RvecLabFrame", "=", " ", 
        RowBox[{"M", " ", 
         RowBox[{
          RowBox[{"Transpose", "[", "LabtoJEulMat", "]"}], " ", ".", " ", 
          RowBox[{"Inverse", "[", "JtoLEulMat", "]"}], ".", 
          RowBox[{"vectorComponents", "[", 
           RowBox[{"{", 
            RowBox[{"rNorm", ",", " ", 
             RowBox[{"\[Pi]", "/", "2"}], ",", "rvecAzimuthAngleLframe"}], 
            "}"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"Return", " ", "[", 
        RowBox[{"{", 
         RowBox[{"rvecAzimuthAngleLframe", ",", 
          RowBox[{"Transpose", "@", "JtoLEulMat"}], ",", "rvecLframe"}], 
         "}"}], "]"}], ";"}]}], "]"}]}], "\[IndentingNewLine]"}]}]], "Input",
