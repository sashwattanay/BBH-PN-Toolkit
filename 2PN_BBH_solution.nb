Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "to", " ", "compute", " ", "the", " ", "azimuthal", " ", 
    "angle", " ", "of", " ", "R", " ", "vector", " ", "in", " ", "L", " ", 
    "frame"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"AzimuthalRvectorLframe", "[", 
     RowBox[{"t_", ",", "NumModel_", ",", "data_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "vectorComponents", ",", "rvecLabFrame", ",", "pvecLabFrame", ",", 
        "s1vecLabFrame", ",", "s2vecLabFrame", ",", "lvecLabFrame", ",", 
        "jvecLabFrame", ",", "LabtoJEulMat", ",", "\[Theta]J", ",", "\[Phi]J",
         ",", "lsolJframe", ",", "lx", ",", "ly", ",", "lz", ",", "\[Xi]1L", ",",
         "\[Xi]2L", ",", "JtoLEulMat", ",", "rvecLframe", ",", "angles", ",", 
