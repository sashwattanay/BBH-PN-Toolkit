8a1e2c8fa0f6"],

Cell[TextData[{
 StyleBox["IMPORTANT:",
  FontWeight->"Bold"],
 " ",
 StyleBox["Our solutions work well when",
  FontWeight->"Bold"],
 " ",
 StyleBox["(a) ",
  FontWeight->"Bold"],
 "both PN parameters are below sub-percent level,  ",
 StyleBox["(b) ",
  FontWeight->"Bold"],
 "eccentricity is less than and away from 1,   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox[
     RowBox[{"(", "c", ")"}],
     FontWeight->"Bold"], 
    StyleBox[
     RowBox[{
      StyleBox[" ",
       FontWeight->"Bold"], " "}]], 
    SubscriptBox["\[Chi]", 
     RowBox[{"1", " ", "or", " ", "2"}]], " "}], TraditionalForm]],
  ExpressionUUID->"480a1ca8-65ca-46b8-937f-d60899ddeb99"],
 " is less than and away from 1,    ",
 StyleBox["(d) ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"1", " ", "or", " ", "2"}]], TraditionalForm]],ExpressionUUID->
  "02f77a40-223f-410c-9d1a-25200272e922"],
 "/(L ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Epsilon]", 
    RowBox[{"1", "/", "2"}]], TraditionalForm]],ExpressionUUID->
  "b4c9663f-97e8-47d6-b9d9-2edcfd02c114"],
 ")  is less than and away from 1.  ",
 StyleBox["(e) ",
  FontWeight->"Bold"],
 "Scaled Hamiltonian h < 0,   ",
 StyleBox["(f) ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Kappa]", "1"], TraditionalForm]],ExpressionUUID->
  "7f632a84-c16e-44b9-baeb-43cea388f333"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Kappa]", "2"], TraditionalForm]],ExpressionUUID->
  "0e6bc92b-1b47-47d6-a825-0f354614eb95"],
 ", \[Gamma] are not 0 or \[Pi] radians (away from spin aligned or \
anti-aligned cases). The values of all these parameters are found in the \
so-called \[OpenCurlyDoubleQuote]summary table\[CloseCurlyDoubleQuote] \
discussed above."
}], "Item",
 CellChangeTimes->{
  3.985869522833911*^9, {3.985875484297421*^9, 3.98587549087123*^9}, {
