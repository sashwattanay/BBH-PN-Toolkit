       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"L", " ", "vector", " ", "in", " ", "J", " ", "frame"}], 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"lsolJframe", "=", 
        RowBox[{"LabtoJEulMat", ".", "lvecLabFrame"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Euler", " ", "Matrix", " ", "from", " ", "J", " ", "to", " ", "L", 
         " ", "frame", " ", "at", " ", "time", " ", "t"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"lx", ",", "ly", ",", "lz"}], "}"}], " ", "=", " ", 
        "lsolJframe"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Xi]2L", ",", " ", "\[Xi]1L"}], "}"}], "=", 
        RowBox[{
         RowBox[{"sphericalAngles", "[", 
          RowBox[{"{", 
           RowBox[{"lx", ",", "ly", ",", "lz"}], "}"}], "]"}], "+", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"JtoLEulMat", " ", "=", 
        RowBox[{"{", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", "\[Xi]1L", "]"}], ",", " ", 
            RowBox[{"Sin", "[", "\[Xi]1L", "]"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              RowBox[{"Sin", "[", "\[Xi]1L", "]"}]}], 
