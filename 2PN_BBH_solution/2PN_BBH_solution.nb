       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Theta]J", ",", " ", "\[Phi]J"}], "}"}], "=", 
        RowBox[{
         RowBox[{"sphericalAngles", "[", "jvecLabFrame", "]"}], "+", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}]}], ";", 
       RowBox[{"LabtoJEulMat", " ", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", "\[Phi]J", "]"}], ",", " ", 
