211672936eec"],

Cell[TextData[{
 "We have a ",
 StyleBox["summary table",
  FontWeight->"Bold"],
 " for the system. Sec. B-2-B-2 generates a summary table for the system with \
its important parameters displayed:       ",
 StyleBox["(a)",
  FontWeight->"Bold"],
 " mass ratio q              ",
 StyleBox["(b)",
  FontWeight->"Bold"],
 " angles b/w angular momenta \[Kappa]1 (L and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "1"], TraditionalForm]],ExpressionUUID->
  "2755d21d-de10-4b47-a6ea-c6c714801c8f"],
 "), \[Kappa]2 (L and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "1"], TraditionalForm]],ExpressionUUID->
  "98a66bc8-bfdd-4540-b2cc-3c50767cc7ac"],
 "), \[Gamma] ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["S", "1"]}], TraditionalForm]],ExpressionUUID->
  "989d2170-f5b7-44ad-8424-075832bd1580"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "2"], TraditionalForm]],ExpressionUUID->
  "5b3ce4b5-39ad-4448-8a16-37d37a11333c"],
 ")           ",
 StyleBox["(c)",
  FontWeight->"Bold"],
 " PN parameter PNa = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", " ", 
    RowBox[{"M", "/", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", 
       SubscriptBox["R", "initial"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"90498606-ce7b-4cb7-bbba-60bb9a027031"],
 ", which does not take eccentricity into account                ",
 StyleBox["(d)",
  FontWeight->"Bold"],
 " PN parameter PNp = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", " ", 
    RowBox[{"M", "/", 
     RowBox[{"(", 
      SuperscriptBox["c", "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "92a2ee91-d557-40c1-ac7f-1c28c8df23b1"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "N"], TraditionalForm]],ExpressionUUID->
  "b2fd51dd-a9ed-41e8-b100-cb19bf645b95"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"1", "-", 
     SubscriptBox["e", "N"]}]}], TraditionalForm]],ExpressionUUID->
  "8a4f6c53-c7a4-44de-ab40-3c783d7b434b"],
 ")), which takes eccentricity into account. Here M = total mass, G =1, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["e", "N"], " ", "="}], TraditionalForm]],ExpressionUUID->
  "961742c5-daa9-431c-ad49-8ee2e6cb4d93"],
 " Newtonian eccentricity, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "n"], TraditionalForm]],ExpressionUUID->
  "b3cd5d20-abbb-41a6-b269-5bf6eb890aa0"],
 " = Newtonian semi major axis for the unscaled R. In this table, are also \
displayed       ",
 StyleBox["(e) ",
  FontWeight->"Bold"],
 "dimensionless spins ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Chi]", "1"], TraditionalForm]],ExpressionUUID->
  "c3beb16e-ce12-4bc1-84f3-c63cf97ababa"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Chi]", "2"], TraditionalForm]],ExpressionUUID->
  "5b4d5500-6fd5-4f72-975a-5897572d217d"],
 "             ",
 StyleBox["(f)",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", 
     RowBox[{"1", " ", "or", " ", "2"}]], "/", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[Epsilon]", 
       RowBox[{"1", "/", "2"}]], "L"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"e9c47e41-a6eb-43d5-8d41-1e848a8f2197"],
 ",        plus other QKP parameters like    scaled Hamiltonian, radial \
eccentricity, mean motion, orbital time period and spin-precession time \
period.",
 StyleBox["        ",
  FontWeight->"Bold"]
}], "Item",
 CellChangeTimes->{
  3.985869522833911*^9, {3.985875484297421*^9, 3.98587549087123*^9}, {
   3.985875686285387*^9, 3.9858757885273542`*^9}, {3.985877283059705*^9, 
   3.985877283061644*^9}, {3.985879845916648*^9, 3.9858798571254873`*^9}, {
   3.985880045264834*^9, 
   3.985880047550359*^9}},ExpressionUUID->"5807559a-c509-4b8b-9b90-\
8a1e2c8fa0f6"],

Cell[TextData[{
 StyleBox["IMPORTANT:",
  FontWeight->"Bold"],
 " ",
 StyleBox["Our solutions work well when",
  FontWeight->"Bold"],
 " ",
 StyleBox["(a) ",
  FontWeight->"Bold"],
 "both PN parameters are below sub-percent level,  ",
 StyleBox["(b) ",
  FontWeight->"Bold"],
 "eccentricity is less than and away from 1,   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox[
     RowBox[{"(", "c", ")"}],
     FontWeight->"Bold"], 
    StyleBox[
     RowBox[{
      StyleBox[" ",
       FontWeight->"Bold"], " "}]], 
    SubscriptBox["\[Chi]", 
     RowBox[{"1", " ", "or", " ", "2"}]], " "}], TraditionalForm]],
  ExpressionUUID->"480a1ca8-65ca-46b8-937f-d60899ddeb99"],
 " is less than and away from 1,    ",
 StyleBox["(d) ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"1", " ", "or", " ", "2"}]], TraditionalForm]],ExpressionUUID->
  "02f77a40-223f-410c-9d1a-25200272e922"],
 "/(L ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Epsilon]", 
    RowBox[{"1", "/", "2"}]], TraditionalForm]],ExpressionUUID->
  "b4c9663f-97e8-47d6-b9d9-2edcfd02c114"],
 ")  is less than and away from 1.  ",
 StyleBox["(e) ",
  FontWeight->"Bold"],
 "Scaled Hamiltonian h < 0,   ",
 StyleBox["(f) ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Kappa]", "1"], TraditionalForm]],ExpressionUUID->
  "7f632a84-c16e-44b9-baeb-43cea388f333"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Kappa]", "2"], TraditionalForm]],ExpressionUUID->
  "0e6bc92b-1b47-47d6-a825-0f354614eb95"],
 ", \[Gamma] are not 0 or \[Pi] radians (away from spin aligned or \
anti-aligned cases). The values of all these parameters are found in the \
so-called \[OpenCurlyDoubleQuote]summary table\[CloseCurlyDoubleQuote] \
discussed above."
}], "Item",
 CellChangeTimes->{
  3.985869522833911*^9, {3.985875484297421*^9, 3.98587549087123*^9}, {
