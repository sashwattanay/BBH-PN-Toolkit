  "5bb8f076-fb07-4d83-9210-6e408d29a726"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "ss"], TraditionalForm]],ExpressionUUID->
  "f1316846-bf96-4041-bc14-12d72e7f49f2"],
 ")"
}], "Text",
